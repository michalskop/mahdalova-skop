{
 "_source": "ÚZIS, Registr zdravotnických pracovníků 2024",
 "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
 "description": "Věková struktura lékařů v ČR: podíl lékařů a lékařek v důchodovém věku (65+), svislé sloupce",
 "width": 450,
 "height": 300,
 "title": {
  "text": "Podíl lékařů a lékařek ve věku 65 a více let podle specializace",
  "subtitle": "Třetina dětských lékařů a lékařek už je v důchodovém věku; v procentech, 2024"
 },
 "data": {
  "values": [
   {"spec": "Dětští praktičtí lékaři", "val": 34.6, "label": "34,6 %", "cat": "Primární péče"},
   {"spec": "Dětští psychiatři", "val": 33.3, "label": "33,3 %", "cat": "Specialisté"},
   {"spec": "Praktičtí lékaři", "val": 30.2, "label": "30,2 %", "cat": "Primární péče"},
   {"spec": "Ostatní lékaři", "val": 15.0, "label": "15,0 %", "cat": "Průměr"}
  ]
 },
 "layer": [
  {
   "params": [
    {
     "name": "serie",
     "select": {"type": "point", "fields": ["cat"]},
     "bind": "legend"
    }
   ],
   "mark": {"type": "bar", "cornerRadiusEnd": 4},
   "encoding": {
    "x": {
     "field": "spec",
     "type": "nominal",
     "title": null,
     "sort": ["Dětští praktičtí lékaři", "Dětští psychiatři", "Praktičtí lékaři", "Ostatní lékaři"],
     "axis": {
      "domain": false,
      "ticks": false,
      "labelAngle": 0,
      "labelPadding": 6,
      "labelExpr": "split(datum.value, ' ')"
     }
    },
    "y": {
     "field": "val",
     "type": "quantitative",
     "title": null,
     "scale": {"domain": [0, 50]},
     "axis": {
      "grid": true,
      "gridColor": "#e8e8dc",
      "domain": false,
      "ticks": false,
      "values": [0, 25, 50],
      "labelExpr": "datum.value + ' %'"
     }
    },
    "color": {
     "field": "cat",
     "type": "nominal",
     "scale": {
      "domain": ["Primární péče", "Specialisté", "Průměr"],
      "range": ["#de1743", "#272a59", "#bcbcb0"]
     },
     "legend": {"title": null}
    },
    "opacity": {
     "condition": {"param": "serie", "value": 1},
     "value": 0.18
    },
    "tooltip": [
     {"field": "spec", "title": "Specializace"},
     {"field": "cat", "title": "Skupina"},
     {"field": "label", "title": "Podíl lékařů a lékařek 65+"}
    ]
   }
  },
  {
   "mark": {
    "type": "text",
    "align": "center",
    "baseline": "bottom",
    "dy": -6,
    "fontSize": 14,
    "fontWeight": "bold",
    "color": "#1a1a1a"
   },
   "encoding": {
    "x": {
     "field": "spec",
     "type": "nominal",
     "sort": ["Dětští praktičtí lékaři", "Dětští psychiatři", "Praktičtí lékaři", "Ostatní lékaři"]
    },
    "y": {
     "field": "val",
     "type": "quantitative",
     "scale": {"domain": [0, 50]}
    },
    "text": {"field": "label"},
    "opacity": {"condition": {"param": "serie", "value": 1}, "value": 0.18}
   }
  }
 ],
 "config": {
  "view": {"stroke": "transparent"}
 }
}
